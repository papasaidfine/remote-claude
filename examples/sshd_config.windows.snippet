# What the bootstrap tool changes in %ProgramData%\ssh\sshd_config on Windows.
# (A timestamped backup sshd_config.claude-bak-<ts> is created next to it, and
# the result is validated with `sshd.exe -t` before the service is restarted.)

# --- global directives set (uncommented / added) -----------------------------

PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys

# Optional (chosen interactively): key-only login.
PasswordAuthentication no

# --- administrators_authorized_keys block gets commented out -----------------
# Windows OpenSSH ships with the block below. While it is active, any user in
# the Administrators group is authenticated against the GLOBAL
# %ProgramData%\ssh\administrators_authorized_keys file and the per-user
# %USERPROFILE%\.ssh\authorized_keys is IGNORED. The tool disables it so admin
# users also use their own authorized_keys:

# claude-bootstrap disabled: Match Group administrators
# claude-bootstrap disabled:        AuthorizedKeysFile __PROGRAMDATA__/ssh/administrators_authorized_keys
