# Example of the managed block that server/setup-server.sh writes into the
# SERVER's ~/.ssh/config. It points at the reverse tunnel, so it only works
# while `ssh -N claude-dev-tunnel` is running on the local machine.
#
# The >>> / <<< markers are how the tool finds and updates its own block on
# re-runs — keep them if you edit the block by hand.

# >>> claude-local (managed by reverse-ssh-bootstrap) >>>
Host claude-local
    HostName 127.0.0.1
    Port 2222
    User localuser
    IdentityFile ~/.ssh/claude_to_local_ed25519
    IdentitiesOnly yes
    # First connection stores the local machine's host key in a dedicated
    # known-hosts file; later mismatches (e.g. a different machine behind the
    # tunnel) still fail loudly.
    StrictHostKeyChecking accept-new
    UserKnownHostsFile ~/.ssh/known_hosts.claude-local
    ForwardAgent no
    ServerAliveInterval 30
    ServerAliveCountMax 3
# <<< claude-local <<<
